# Neon serverless Postgres connection string (from console.neon.tech)
DATABASE_URL=

# Resend API key for verification + deadline alert emails (from resend.com)
RESEND_API_KEY=

# Sender address — must be on a domain verified in Resend
# (defaults to "OS Programs Tracker <alerts@osprograms.dev>")
EMAIL_FROM=alerts@osprograms.dev

# Public base URL of the deployed site (used in emails, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
